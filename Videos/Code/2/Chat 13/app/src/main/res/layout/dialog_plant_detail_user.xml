<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootUserDetail"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_modern"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/textPlantName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.PlantCare.Headline"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:text="@string/detail_placeholder_name"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/pc_outlineVariant"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:id="@+id/contentScrollUser"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:id="@+id/contentContainerUser"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- صورة دائرية تظهر دائماً -->
            <ImageView
                android:id="@+id/plantImageView"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_bg"
                android:clipToOutline="true"
                android:contentDescription="@string/app_name"
                android:visibility="visible"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_default_plant"/>

            <!-- نخفي Room/Start نهائياً (IDs موجودة لتوافق الكود إن لزم) -->
            <TextView
                android:id="@+id/labelRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="@string/detail_label_room"/>
            <TextView
                android:id="@+id/textRoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/labelStartDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="@string/detail_label_start"/>
            <TextView
                android:id="@+id/textStartDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <!-- Bewässerung -->
            <TextView
                android:id="@+id/labelWatering"
                style="@style/PlantCareFieldLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_label_watering" />
            <TextView
                android:id="@+id/textWatering"
                style="@style/PlantCareFieldValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_placeholder_dash"
                android:layout_marginBottom="12dp"/>

            <!-- Licht -->
            <TextView
                android:id="@+id/labelLighting"
                style="@style/PlantCareFieldLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_label_lighting" />
            <TextView
                android:id="@+id/textLighting"
                style="@style/PlantCareFieldValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_placeholder_dash"
                android:layout_marginBottom="12dp"/>

            <!-- Boden -->
            <TextView
                android:id="@+id/labelSoil"
                style="@style/PlantCareFieldLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_label_soil" />
            <TextView
                android:id="@+id/textSoil"
                style="@style/PlantCareFieldValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_placeholder_dash"
                android:layout_marginBottom="12dp"/>

            <!-- Düngung -->
            <TextView
                android:id="@+id/labelFertilizing"
                style="@style/PlantCareFieldLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_label_fertilizing" />
            <TextView
                android:id="@+id/textFertilizing"
                style="@style/PlantCareFieldValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_placeholder_dash"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/textPersonalNoteLabel"
                style="@style/PlantCareFieldLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_label_info"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/textPersonalNote"
                style="@style/PlantCareFieldValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/detail_placeholder_dash"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/buttonBarUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEdit"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/detail_action_edit"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCamera"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/detail_action_take_cover"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonOpenJournal"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/journal_open"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonViewPhotos"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/detail_action_view_archive"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGrowthMemoir"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/memoir_button_label"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonFamilyShare"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/share_button_label"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDeletePlant"
            style="@style/PlantCare.Button.Danger"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/detail_action_delete"/>

        <Space android:layout_width="match_parent" android:layout_height="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonClose"
            style="@style/PlantCare.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/detail_action_close"/>

        <!-- زر نقل النبتة إلى غرفة أخرى (نضيفه هنا فقط UI؛ السلوك ستضيفه لاحقاً) -->
        <Space android:layout_width="match_parent" android:layout_height="10dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMoveToRoom"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/detail_action_move_room"/>

        <!-- مخفي للمستخدم -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAddToMyPlants"
            style="@style/PlantCareOutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/add_plant"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>