<?xml version="1.0" encoding="utf-8"?>
<!--
  الحوار الابتدائي للمصادقة:
  - يحتوي أزرار Google / البريد الإلكتروني.
  - AuthStartDialogFragment يعتمد فقط على المعرّفات:
      btnGoogle, btnEmail, textHaveAccount, buttonClose
  - العرض النهائي يُضبط إلى 90% في الكود (onStart) وليس هنا.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="@color/card_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="28dp">

            <!-- العنوان + زر الإغلاق -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/welcome"
                    android:textAppearance="@style/TextAppearance.PlantCare.Headline"
                    android:textSize="22sp" />

                <ImageButton
                    android:id="@+id/buttonClose"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="@color/pc_onSurfaceSecondary"
                    android:padding="10dp"
                    android:contentDescription="@string/close"/>
            </LinearLayout>

            <!-- زر Google -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/PlantCare.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/auth_button_google_login"
                android:layout_marginBottom="12dp" />

            <!-- Phase 6.1: Apple Sign-In -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApple"
                style="@style/PlantCare.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/auth_apple_button"
                android:layout_marginBottom="12dp" />

            <!-- زر البريد -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEmail"
                style="@style/PlantCare.Button.Filled"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/auth_button_email_continue"
                android:layout_marginBottom="8dp" />

            <!-- Phase 6.2: Magic Link -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMagicLink"
                style="@style/PlantCare.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/auth_magic_link_label"
                android:layout_marginBottom="4dp" />

            <!-- رابط: لدي حساب -->
            <TextView
                android:id="@+id/textHaveAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_link_have_account"
                android:textColor="@color/pc_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"/>

            <!-- Phase 1.1: progress while Google round-trip -->
            <ProgressBar
                android:id="@+id/authStartProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

            <!-- Phase 1.2: inline error replaces Toast -->
            <TextView
                android:id="@+id/authStartError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/pc_error"
                android:textSize="13sp"
                android:layout_marginTop="10dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>