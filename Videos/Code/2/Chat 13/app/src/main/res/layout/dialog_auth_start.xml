<?xml version="1.0" encoding="utf-8"?>
<!--
  الحوار الابتدائي للمصادقة:
  - يحتوي أزرار Google / (Facebook مخفي) / البريد الإلكتروني.
  - AuthStartDialogFragment يعتمد فقط على المعرّفات:
      btnGoogle, btnFacebook, btnEmail, textHaveAccount, buttonClose
  - تم تبسيطه وإزالة أي حقول غير مستخدمة لمنع التضارب والانهيارات.
  - العرض النهائي يُضبط إلى 90% في الكود (onStart) وليس هنا.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="@color/card_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="28dp">

            <!-- العنوان + زر الإغلاق -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/welcome"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:fontFamily="@font/playfair_display"/>

                <ImageButton
                    android:id="@+id/buttonClose"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="@string/close"/>
            </LinearLayout>

            <!-- زر Google -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogle"
                style="@style/Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Mit Google anmelden"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp" />

            <!-- زر Facebook (مخفي حالياً) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFacebook"
                style="@style/Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Mit Facebook anmelden"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- زر البريد -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEmail"
                style="@style/Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Mit E‑Mail fortfahren"
                android:textAllCaps="false"
                android:layout_marginBottom="8dp" />

            <!-- رابط: لدي حساب -->
            <TextView
                android:id="@+id/textHaveAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schon ein Konto? Hier anmelden"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"/>
        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>