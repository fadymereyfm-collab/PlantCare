<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pc_background">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/pc_background"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/close"
            android:tint="@color/pc_onSurface"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/identify_title"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@color/pc_onSurface"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Image Preview Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/pc_outline"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="260dp">

                    <!-- Placeholder when no image -->
                    <LinearLayout
                        android:id="@+id/placeholderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/pc_surfaceVariant">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_camera"
                            android:tint="@color/pc_onSurfaceSecondary"
                            android:contentDescription="@null" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/identify_placeholder"
                            android:textColor="@color/pc_onSurfaceSecondary"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Actual image preview -->
                    <ImageView
                        android:id="@+id/imagePreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@string/plant_image" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons: Camera & Gallery -->
            <LinearLayout
                android:id="@+id/actionButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/identify_camera"
                    android:textColor="@color/pc_onSurface"
                    app:icon="@drawable/ic_camera"
                    app:iconTint="@color/pc_onSurface"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/pc_outline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallery"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/identify_gallery"
                    android:textColor="@color/pc_onSurface"
                    app:icon="@drawable/ic_gallery"
                    app:iconTint="@color/pc_onSurface"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/pc_outline" />
            </LinearLayout>

            <!-- Organ selector (Blatt, Blüte, Frucht, Rinde) -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/organChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAuto"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organ_auto"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLeaf"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organ_leaf" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFlower"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organ_flower" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFruit"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organ_fruit" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBark"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organ_bark" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Identify Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIdentify"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/identify_button"
                android:textSize="16sp"
                android:enabled="false"
                app:cornerRadius="12dp"
                android:backgroundTint="@color/pc_success"
                android:textColor="@color/pc_onPrimary"
                android:layout_marginBottom="16dp" />

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:visibility="gone"
                android:indeterminateTint="@color/pc_primary"
                android:layout_marginBottom="16dp" />

            <!-- Error / No Results message -->
            <TextView
                android:id="@+id/txtMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/pc_onSurfaceSecondary"
                android:textSize="14sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- Results List -->
            <LinearLayout
                android:id="@+id/resultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/identify_results_title"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/pc_onSurface"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/resultsRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
