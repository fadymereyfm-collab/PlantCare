<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="@color/card_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Header row: title + close -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/paywall_title"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/playfair_display"/>

                <ImageButton
                    android:id="@+id/btnPaywallClose"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:contentDescription="@string/close"/>
            </LinearLayout>

            <!-- Optional contextual message -->
            <TextView
                android:id="@+id/txtPaywallContext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- Free vs Pro comparison -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/paywall_comparison"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"/>

            <!-- Monthly option -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_outline"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txtMonthlyPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/paywall_monthly_label"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"/>

                <Button
                    android:id="@+id/btnMonthly"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/paywall_subscribe"
                    android:backgroundTint="@color/pc_primary"
                    android:textColor="@color/pc_onPrimary"
                    android:enabled="false"/>
            </LinearLayout>

            <!-- Yearly option (recommended) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_outline"
                android:padding="12dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txtYearlyPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/paywall_yearly_label"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"/>

                <Button
                    android:id="@+id/btnYearly"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/paywall_subscribe_recommended"
                    android:backgroundTint="@color/pc_success"
                    android:textColor="@color/pc_onPrimary"
                    android:enabled="false"/>
            </LinearLayout>

            <!-- Lifetime option -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_outline"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/txtLifetimePrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/paywall_lifetime_label"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"/>

                <Button
                    android:id="@+id/btnLifetime"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/paywall_buy_lifetime"
                    android:backgroundTint="@color/text_secondary"
                    android:textColor="@color/pc_onPrimary"
                    android:enabled="false"/>
            </LinearLayout>

            <!-- Restore purchases -->
            <Button
                android:id="@+id/btnRestorePurchases"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/paywall_restore"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>
