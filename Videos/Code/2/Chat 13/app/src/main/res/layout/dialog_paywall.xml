<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="20dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/pc_surface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- Header row: title + close -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/paywall_title"
                    android:textAppearance="@style/TextAppearance.PlantCare.Headline"
                    android:textSize="22sp" />

                <ImageButton
                    android:id="@+id/btnPaywallClose"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    app:tint="@color/pc_onSurfaceSecondary"
                    android:padding="10dp"
                    android:contentDescription="@string/close"/>
            </LinearLayout>

            <!-- Optional contextual message -->
            <TextView
                android:id="@+id/txtPaywallContext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.PlantCare.BodySmall"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- Free vs Pro comparison -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/paywall_comparison"
                android:textAppearance="@style/TextAppearance.PlantCare.BodySmall"
                android:layout_marginBottom="16dp"/>

            <!-- Monthly option -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/pc_outlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/pc_surfaceContainerLow">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/txtMonthlyPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/paywall_monthly_label"
                        android:textAppearance="@style/TextAppearance.PlantCare.Subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMonthly"
                        style="@style/PlantCare.Button.Tonal"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/paywall_subscribe"
                        android:enabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Yearly option (recommended) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/pc_primary"
                app:strokeWidth="2dp"
                app:cardBackgroundColor="@color/pc_primaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/txtYearlyPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/paywall_yearly_label"
                        android:textAppearance="@style/TextAppearance.PlantCare.Subtitle"
                        android:textColor="@color/pc_onPrimaryContainer" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnYearly"
                        style="@style/PlantCare.Button.Filled"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/paywall_subscribe_recommended"
                        android:enabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Lifetime option -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/pc_outlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/pc_surfaceContainerLow">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/txtLifetimePrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/paywall_lifetime_label"
                        android:textAppearance="@style/TextAppearance.PlantCare.Subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLifetime"
                        style="@style/PlantCare.Button.Outlined"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:text="@string/paywall_buy_lifetime"
                        android:enabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Restore purchases -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestorePurchases"
                style="@style/PlantCare.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/paywall_restore"
                android:textColor="@color/pc_onSurfaceSecondary"/>

        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>
