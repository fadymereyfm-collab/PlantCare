<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/pc_surface">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <!-- Plant image -->
            <ImageView
                android:id="@+id/ivPlantImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/plant_image"
                android:background="@color/pc_surfaceVariant" />

            <!-- Selection overlay -->
            <View
                android:id="@+id/selectionOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#80000000"
                android:visibility="gone" />

            <!-- Checkmark icon -->
            <ImageView
                android:id="@+id/ivCheckmark"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_view"
                android:tint="@color/pc_onPrimary"
                android:visibility="gone"
                android:contentDescription="@string/cd_selected" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Plant name -->
            <TextView
                android:id="@+id/tvPlantName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/pc_onSurface"
                android:ellipsize="end"
                android:maxLines="2" />

            <!-- Checkbox -->
            <CheckBox
                android:id="@+id/checkboxSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:buttonTint="@color/pc_primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
