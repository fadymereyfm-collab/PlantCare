<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- أنماط التقويم القديم (MaterialCalendarView) -->
    <style name="CalendarHeaderTextAppearance" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?android:textColorPrimary</item>
    </style>

    <style name="CalendarWeekDayTextAppearance" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textColor">?android:textColorSecondary</item>
    </style>

    <style name="CalendarDateTextAppearance" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?android:textColorPrimary</item>
    </style>
</resources>