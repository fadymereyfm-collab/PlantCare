<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/pc_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/sideStripe"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/pc_success" />

        <ImageView
            android:id="@+id/imagePlantThumb"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/circle_bg"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:contentDescription="@string/plant_image" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textPlantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plant name"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/pc_onSurface" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <!-- Reminder due date — locale-formatted at bind time. -->
                <TextView
                    android:id="@+id/textDueDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    tools:text="12. Mai" />

                <!-- شارة التأخير -->
                <TextView
                    android:id="@+id/textOverdue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+1"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/pc_error"
                    android:visibility="gone"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/imageTypeIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_watering_can"
            app:tint="@null"
            android:contentDescription="@string/water_plant" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>