<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined secondary button — transparent fill, sage stroke, sage
     text. Used by secondary onboarding buttons (SKIP, SIGN IN). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1.5dp"
        android:color="@color/pc_primary" />
    <corners android:radius="24dp" />
</shape>
