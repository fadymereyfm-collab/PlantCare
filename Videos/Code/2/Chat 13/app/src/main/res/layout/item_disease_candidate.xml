<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/pc_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Header: rank badge + name + confidence -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txtRank"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/pc_onPrimary"
                android:background="@drawable/bg_circle_primary"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/txtDiseaseName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/pc_onSurface" />

            <TextView
                android:id="@+id/txtConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="@color/pc_primary"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtAdvice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/pc_onSurface"
            android:textSize="13sp"
            android:layout_marginTop="8dp" />

        <!-- Reference-image carousel section -->
        <TextView
            android:id="@+id/txtReferenceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disease_reference_section_label"
            android:textColor="@color/pc_onSurfaceSecondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp">

            <ProgressBar
                android:id="@+id/refImagesProgress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/pc_primary"
                android:visibility="visible" />

            <TextView
                android:id="@+id/txtRefImagesEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="@color/pc_onSurfaceSecondary"
                android:textSize="12sp"
                android:text="@string/disease_reference_none"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/refImagesRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Attribution + match button -->
        <TextView
            android:id="@+id/txtAttribution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/pc_onSurfaceSecondary"
            android:textSize="11sp"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMatch"
            style="@style/PlantCare.Button.Filled"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="@string/disease_candidate_match"
            android:textSize="14sp"
            app:icon="@drawable/ic_check" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
