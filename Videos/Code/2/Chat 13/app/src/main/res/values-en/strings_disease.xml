    <!-- GDPR consent on first diagnosis use -->
    <string name="disease_consent_title">Enable disease diagnosis?</string>
    <string name="disease_consent_message">To diagnose, the photo you take will be sent to the Google Gemini AI service for processing. No personal data or location is included. Processing is performed under Art. 6(1)(b) GDPR (contract performance).\n\nAfter the diagnosis, reference images are loaded from Wikipedia/Wikimedia Commons, iNaturalist and PlantVillage for visual comparison. These services may log your IP address — your own photo is NOT sent to them.\n\nPrivacy policy: https://fadymereyfm-collab.github.io/plantcare-privacy/</string>
    <string name="disease_consent_accept">Accept and continue</string>
    <string name="disease_consent_decline">Cancel</string>
    <string name="disease_consent_declined_toast">Diagnosis cancelled — no data was sent.</string>

